# Adaptive Agentic RAG System — environment variables
# Copy to .env and fill in values. Do not commit .env.

# OpenRouter (primary LLM gateway)
OPENROUTER_API_KEY=

# Default model (OpenRouter model id)
DEFAULT_MODEL=google/gemini-2.0-flash-exp

# Retrieval: vector | hybrid | adaptive
RETRIEVAL_STRATEGY=adaptive

# Vector store persistence path
VECTOR_STORE_PATH=./data/vector_store

# Optional: embedding model (if different from LLM)
# EMBEDDING_MODEL=
