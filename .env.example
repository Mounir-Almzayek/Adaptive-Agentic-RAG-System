# Adaptive Agentic RAG System — environment variables
# Copy to .env and fill in values. Do not commit .env.

# --- Required for default provider ---
# OpenRouter (primary LLM gateway)
OPENROUTER_API_KEY=

# --- Optional (defaults shown) ---
# Provider: currently only "openrouter" is supported
DEFAULT_PROVIDER=openrouter
# OpenRouter model id (e.g. google/gemini-2.0-flash-exp, openai/gpt-4o-mini)
DEFAULT_MODEL=google/gemini-2.0-flash-exp
# Retrieval: vector | hybrid | adaptive (used in Phase 2+)
RETRIEVAL_STRATEGY=adaptive
# Vector store persistence path
VECTOR_STORE_PATH=./data/vector_store
# Embedding model (if different from LLM; Phase 2+)
# EMBEDDING_MODEL=
